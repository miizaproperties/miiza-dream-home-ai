# Main API base URL (used for properties, contacts, etc.)
# Development:
# VITE_API_BASE_URL=http://localhost:8000/api
# Production (e.g. Railway):
VITE_API_BASE_URL=https://miiza-dream-home-ai-production.up.railway.app/api

# Optional: override dashboard API base (defaults to VITE_API_BASE_URL + /dashboard)
# VITE_DASHBOARD_API_BASE_URL=https://miiza-dream-home-ai-production.up.railway.app/api/dashboard

# Optional: backend base URL for media links
# VITE_BACKEND_BASE_URL=https://miiza-dream-home-ai-production.up.railway.app
