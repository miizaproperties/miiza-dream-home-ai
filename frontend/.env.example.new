# Environment Configuration Example
# Copy this file to .env.local for development

# Development API URLs (default)
VITE_API_BASE_URL=http://localhost:8001/api
VITE_DASHBOARD_API_BASE_URL=http://localhost:8001/api/dashboard
VITE_BACKEND_BASE_URL=http://localhost:8001

# For production, create .env.production with your actual domain:
# VITE_API_BASE_URL=https://your-domain.com/api
# VITE_DASHBOARD_API_BASE_URL=https://your-domain.com/api/dashboard
# VITE_BACKEND_BASE_URL=https://your-domain.com

# App Configuration
VITE_APP_NAME=Miiza Dream Home AI
VITE_APP_DESCRIPTION=Find your dream property in Kenya