# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,miiza-dream-home-ai-production.up.railway.app

# CORS Configuration (comma-separated list of allowed origins)
# Example: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# CORS_ALLOWED_ORIGINS=

# CSRF Trusted Origins (comma-separated list)
# Example: CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=

# Database Configuration
# Option 1: Use DATABASE_URL (recommended for Railway, Heroku, etc.)
# DATABASE_URL=postgresql://user:password@host:port/database

# Option 2: Use individual database settings
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=railway
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your_db_password
# DATABASE_HOST=tramway.proxy.rlwy.net
# DATABASE_PORT=23900

# If neither is set, SQLite will be used as default

# Firebase Configuration
FIREBASE_STORAGE_BUCKET=automotive-5f3b5.firebasestorage.app
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=Miizarealtors@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password-here